# Firebase web config — set apiKey from your own Firebase web app.
# All values come from your Firebase project (Console -> Project settings).
NEXT_PUBLIC_FIREBASE_API_KEY=your_web_api_key_here

# Firebase project config (set these to YOUR project)
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
# NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Intercom customer-support widget — workspace App ID (not a secret, but
# env-controlled so we don't bake it into the bundle). When unset the
# widget no-ops silently, which is the expected dev-local experience.
NEXT_PUBLIC_INTERCOM_APP_ID=

# Firebase Cloud Messaging VAPID public key for web push.
# Generate / copy from: Firebase Console → Project Settings → Cloud Messaging →
#   Web configuration → Web Push certificates → "Key pair"
# Required for in-browser push notifications. Without it getToken() fails and
# the "Enable notifications" UI silently returns null.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# BYO BILLING (open-core) — the open-source build ships billing STUBS only
# (every user is the free tier). To enable real purchases, bring your own
# billing provider and set the hosted-checkout base URL below. Each seat band's
# checkout URL is built as `${base}/${webOfferId}/${firebaseUid}` (see
# lib/billing/seat-bands.ts). When unset, checkout points at a non-functional
# placeholder so unconfigured billing is obvious.
# NEXT_PUBLIC_CHECKOUT_BASE_URL=https://pay.example.com
