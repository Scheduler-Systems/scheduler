# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep example template
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
# next-env.d.ts is auto-generated but committed for type checking
# next-env.d.ts

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Firebase emulator debug logs
firebase-debug.log
firestore-debug.log
ui-debug.log

# nested git worktrees (work lives on their own branches)
worktrees/
