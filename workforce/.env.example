# Copy to .env (gitignored). NEVER commit real values.

# =========================================================================
# Models — cost-first routing (DeepSeek default; escalate for browser/computer-use/complex)
# =========================================================================
# Default tier (ordinary agent reasoning): DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Escalation tier (browser automation / computer use / complex tasks):
ESCALATION_PROVIDER=anthropic        # anthropic | openai
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini            # set to your exact OpenAI model id

# =========================================================================
# LangSmith / LangGraph Platform (EU region — org b0ba914d)
# Generate at: LangSmith -> Settings -> API Keys -> Create API Key (type: Service Key)
# =========================================================================
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGSMITH_PROJECT=scheduler-qa

# =========================================================================
# GitHub App (least-privilege, per-repo): gated PR/issue/check-run + workflow dispatch
# =========================================================================
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_DISPATCH_TOKEN=

# =========================================================================
# Observability + governance (both fail-safe / optional)
# =========================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=qa-agent-platform
GAL_GOVERNANCE_ENDPOINT=
GAL_GOVERNANCE_TOKEN=

# =========================================================================
# Slack — agent collaboration layer
# Create a Slack app at https://api.slack.com/apps with these bot token scopes:
#   channels:read, channels:write, chat:write, chat:write.customize
# Install the app to your workspace and copy the "Bot User OAuth Token" (xoxb-...).
# Fallback: set SLACK_WEBHOOK_URL to an incoming webhook URL (single channel only).
# =========================================================================
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=

# Per-channel overrides (optional — defaults come from agent_toolkit/slack_tool.py routing table)
# SLACK_CHANNEL_DAILY_DIGEST=#executive-updates
# SLACK_CHANNEL_CEO=#executive-updates
# SLACK_CHANNEL_CTO=#engineering
# SLACK_CHANNEL_CMO=#marketing
# SLACK_CHANNEL_QA_LEAD_AGGREGATOR=#qa-reports

# Per-agent icon overrides (optional)
# SLACK_AGENT_ICON_DAILY_DIGEST=:calendar:
# SLACK_AGENT_ICON_CEO=:necktie:
