<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  conversion_growth_analyst LaunchAgent — REVENUE. Weekly (Mon 09:15) it reads the RC funnel +
  paywall + trials and drafts conversion experiments. PROBATION = propose-only (OPS_REPORT_ONLY=1
  + GITHUB_OPS_REPORT_ONLY=1): writes the local digest + traces; the GitHub draft is NOT filed.
  Needs REVENUECAT_API_KEY + REVENUECAT_PROJECT_ID for live funnel data (falls back to the
  declared baseline in docs/growth/scheduler_positioning.json until then).

  Install:
    cp docs/launchd/com.schedulersystems.conversion-growth-analyst.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.schedulersystems.conversion-growth-analyst.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.schedulersystems.conversion-growth-analyst</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/scheduler-systems/Documents/scheduler-systems-ltd/Scheduler-Systems/qa-agent-platform/worktrees/ops-fleet &amp;&amp; ENVF=.env; [ -f "$ENVF" ] || ENVF=/Users/scheduler-systems/Documents/scheduler-systems-ltd/Scheduler-Systems/qa-agent-platform/.env; set -a &amp;&amp; . "$ENVF" &amp;&amp; set +a &amp;&amp; export LANGSMITH_TRACING=true LANGSMITH_PROJECT=scheduler-qa OPS_REPORT_ONLY=1 GITHUB_OPS_REPORT_ONLY=1 &amp;&amp; ./.venv/bin/python scripts/run_ops_graph.py conversion_growth_analyst</string>
  </array>

  <!-- Weekly: Monday 09:15 local (before the daily_digest at 09:30). -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>1</integer>
    <key>Hour</key><integer>9</integer>
    <key>Minute</key><integer>15</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/scheduler-systems/Documents/scheduler-systems-ltd/.tmp/conversion-growth-analyst/launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/scheduler-systems/Documents/scheduler-systems-ltd/.tmp/conversion-growth-analyst/launchd.log</string>
</dict>
</plist>
