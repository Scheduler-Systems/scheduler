<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  store_health_checker LaunchAgent — STAGED, do NOT load until sign-off.

  Daily RevenueCat/store health: non-purchasable SKUs, offering/trial drift, paywall
  reachability. PROBATION = report-only (OPS_REPORT_ONLY=1 + GITHUB_OPS_REPORT_ONLY=1): the
  digest is written locally + traced; the GitHub issue is NOT filed. Drop those envs (and set
  AGENT_AUTONOMY=auto, or run attended) to let it file alerts after promotion. A 'high'
  severity finding (non-purchasable SKU or paywall down) is revenue-blocking — escalate fast.

  This graph is ALSO cloud-deployable (registered in langgraph.json).

  Install (after sign-off):
    cp docs/launchd/com.schedulersystems.store-health-checker.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.schedulersystems.store-health-checker.plist
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.schedulersystems.store-health-checker</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/scheduler-systems/Documents/scheduler-systems-ltd/Scheduler-Systems/qa-agent-platform/worktrees/ops-fleet &amp;&amp; ENVF=.env; [ -f "$ENVF" ] || ENVF=/Users/scheduler-systems/Documents/scheduler-systems-ltd/Scheduler-Systems/qa-agent-platform/.env; set -a &amp;&amp; . "$ENVF" &amp;&amp; set +a &amp;&amp; export LANGSMITH_TRACING=true LANGSMITH_PROJECT=scheduler-qa OPS_REPORT_ONLY=1 GITHUB_OPS_REPORT_ONLY=1 &amp;&amp; ./.venv/bin/python scripts/run_ops_graph.py store_health_checker</string>
  </array>

  <!-- Daily: 08:30 local. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>8</integer>
    <key>Minute</key><integer>30</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/scheduler-systems/Documents/scheduler-systems-ltd/.tmp/store-health-checker/launchd.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/scheduler-systems/Documents/scheduler-systems-ltd/.tmp/store-health-checker/launchd.log</string>
</dict>
</plist>
